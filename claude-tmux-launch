#!/usr/bin/env bash
# claude-tmux-launch — launcher for persistent Claude agent services.
#
# Starts claude inside a detached tmux session (a real virtual PTY), which
# keeps the MCP Telegram plugin connection alive for multi-turn conversations.
# Loops until the tmux session ends so the service manager (systemd/launchd)
# can track liveness and restart on exit.
#
# Usage: claude-tmux-launch <agent-name>
#
# Expected env vars:
#   TELEGRAM_STATE_DIR   — per-agent state dir (~/.claude/channels/telegram-<name>)
#   TELEGRAM_BOT_TOKEN   — bot token (auto-sourced from STATE_DIR/.env if not set)
#   PATH                 — must include bun and claude

set -euo pipefail

AGENT="${1:?agent name required}"
SESSION="claude-${AGENT}"

# Source .env from the state dir if TELEGRAM_BOT_TOKEN isn't already set.
# systemd uses EnvironmentFile for this; launchd doesn't have an equivalent.
if [[ -z "${TELEGRAM_BOT_TOKEN:-}" && -n "${TELEGRAM_STATE_DIR:-}" && -f "${TELEGRAM_STATE_DIR}/.env" ]]; then
  set -a
  source "${TELEGRAM_STATE_DIR}/.env"
  set +a
fi

# Verify required env vars are set.
for var in TELEGRAM_STATE_DIR TELEGRAM_BOT_TOKEN; do
  if [[ -z "${!var:-}" ]]; then
    echo "Error: ${var} is not set." >&2
    echo "  If running manually: export ${var}=... before launching." >&2
    echo "  If running via systemd: check the unit's Environment/EnvironmentFile." >&2
    echo "  If running via launchd: check EnvironmentVariables in the plist." >&2
    exit 1
  fi
done

# Kill any stale server from a previous run (per-agent socket = safe to nuke entirely).
tmux -L "$AGENT" kill-server 2>/dev/null || true

# Launch claude inside a new detached tmux session on a per-agent tmux server.
# Per-agent server (-L) isolates this agent's processes in its own cgroup, so
# KillMode=control-group in the unit file cleanly reaps all orphans on stop.
# Env vars are passed explicitly — tmux sessions don't inherit the systemd env.
CLAUDE_CMD="claude --dangerously-skip-permissions --channels plugin:telegram@claude-plugins-official"
[[ -n "${CLAUDE_MODEL:-}" ]] && CLAUDE_CMD+=" --model ${CLAUDE_MODEL}"

tmux -L "$AGENT" new-session -d -s "$SESSION" \
  -e "TELEGRAM_STATE_DIR=${TELEGRAM_STATE_DIR}" \
  -e "TELEGRAM_BOT_TOKEN=${TELEGRAM_BOT_TOKEN}" \
  -e "PATH=${PATH}" \
  "$CLAUDE_CMD"

# Stay alive while the session exists. When claude exits the tmux window closes,
# the session is destroyed, this loop exits, and systemd restarts the service.
#
# Health check: the bun plugin process can die while claude stays alive, leaving
# the bot silently unresponsive. If bun hasn't been running for HEALTH_GRACE
# seconds, kill the session so systemd restarts everything cleanly.
HEALTH_GRACE=120  # seconds to wait after launch before checking for bun
LAUNCH_TIME=$(date +%s)
BUN_MISSING_SINCE=""

# Recursively collect all descendant PIDs of $1 (one PID per line).
descendants() {
  local parent=$1
  local kids
  kids=$(pgrep -P "$parent" 2>/dev/null) || return 0
  for kid in $kids; do
    echo "$kid"
    descendants "$kid"
  done
}

while tmux -L "$AGENT" has-session -t "$SESSION" 2>/dev/null; do
  sleep 10

  # Skip health checks during startup grace period.
  NOW=$(date +%s)
  if (( NOW - LAUNCH_TIME < HEALTH_GRACE )); then
    continue
  fi

  # Walk the full process tree to detect bun and active tool processes.
  PANE_PID=$(tmux -L "$AGENT" list-panes -t "$SESSION" -F '#{pane_pid}' 2>/dev/null) || continue

  HAS_BUN=false
  HAS_TOOL=false
  while read -r pid; do
    [[ -z "$pid" ]] && continue
    cmd=$(ps -p "$pid" -o comm= 2>/dev/null) || continue
    case "$cmd" in
      bun*)    HAS_BUN=true ;;
      claude*) ;;  # the agent itself — not a tool
      *)       HAS_TOOL=true ;;
    esac
  done < <(descendants "$PANE_PID")

  if $HAS_BUN; then
    BUN_MISSING_SINCE=""
    continue
  fi

  if $HAS_TOOL; then
    # Claude is actively running tools — don't penalise for bun absence.
    [[ -n "$BUN_MISSING_SINCE" ]] && \
      echo "$(date -Iseconds) [health] active tool work detected, resetting bun timer for ${AGENT}" >&2
    BUN_MISSING_SINCE=""
    continue
  fi

  # No bun, no active tools — start (or continue) the missing timer.
  if [[ -z "$BUN_MISSING_SINCE" ]]; then
    BUN_MISSING_SINCE=$NOW
    echo "$(date -Iseconds) [health] bun process not found for ${AGENT}, watching..." >&2
    continue
  fi

  # If bun has been missing for over 5 minutes, kill the session to trigger restart.
  if (( NOW - BUN_MISSING_SINCE > 300 )); then
    echo "$(date -Iseconds) [health] bun missing for 5m — killing session ${SESSION} for restart" >&2
    tmux -L "$AGENT" kill-server 2>/dev/null || true
    break
  fi
done
