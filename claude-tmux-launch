#!/usr/bin/env bash
# claude-tmux-launch — launcher for persistent Claude agent services.
#
# Starts claude inside a detached tmux session (a real virtual PTY), which
# keeps the MCP channel plugin connection alive for multi-turn conversations.
# Loops until the tmux session ends so the service manager (systemd/launchd)
# can track liveness and restart on exit.
#
# Usage: claude-tmux-launch <agent-name>
#
# Channel selection (set in agent .env):
#   CLAUDE_CHANNEL_PLUGIN  — channel spec:
#     telegram@claude-plugins-official  — Telegram (default)
#     server:matrix                     — Rust Matrix binary (cc_matrix_channel)
#
# Telegram env vars (default):
#   TELEGRAM_STATE_DIR   — per-agent state dir (~/.claude/channels/telegram-<name>)
#   TELEGRAM_BOT_TOKEN   — bot token (auto-sourced from STATE_DIR/.env if not set)
#
# Matrix env vars (when CLAUDE_CHANNEL_PLUGIN=server:matrix):
#   All Matrix config is in ~/.claude.json mcpServers.matrix.env for the project.
#   No extra env vars needed here.
#
# PATH must include bun, cc_matrix_channel, and claude.

set -euo pipefail

AGENT="${1:?agent name required}"
SESSION="claude-${AGENT}"

CHANNEL_PLUGIN="${CLAUDE_CHANNEL_PLUGIN:-telegram@claude-plugins-official}"

# Source channel .env for launchd compatibility (systemd uses EnvironmentFile).
if [[ "$CHANNEL_PLUGIN" == server:* ]]; then
  # Server-type channel (e.g. server:matrix): all config is in .claude.json mcpServers.
  # No special env vars needed here — just pass an empty set.
  CHANNEL_ENV=()
else
  if [[ -z "${TELEGRAM_BOT_TOKEN:-}" && -n "${TELEGRAM_STATE_DIR:-}" && -f "${TELEGRAM_STATE_DIR}/.env" ]]; then
    set -a; source "${TELEGRAM_STATE_DIR}/.env"; set +a
  fi
  for var in TELEGRAM_STATE_DIR TELEGRAM_BOT_TOKEN; do
    if [[ -z "${!var:-}" ]]; then
      echo "Error: ${var} is not set." >&2; exit 1
    fi
  done
  # Pass only TELEGRAM_STATE_DIR — the plugin reads the token from STATE_DIR/.env directly.
  # Do NOT pass TELEGRAM_BOT_TOKEN via -e: it would appear in 'ps aux' output.
  CHANNEL_ENV=(-e "TELEGRAM_STATE_DIR=${TELEGRAM_STATE_DIR}")
fi

# Kill any stale server from a previous run (per-agent socket = safe to nuke entirely).
tmux -L "$AGENT" kill-server 2>/dev/null || true

# Launch claude inside a new detached tmux session on a per-agent tmux server.
# Per-agent server (-L) isolates this agent's processes in its own cgroup, so
# KillMode=control-group in the unit file cleanly reaps all orphans on stop.
# Env vars are passed explicitly — tmux sessions don't inherit the systemd env.
if [[ "$CHANNEL_PLUGIN" == server:* ]]; then
  CLAUDE_CMD="claude --dangerously-skip-permissions --dangerously-load-development-channels ${CHANNEL_PLUGIN}"
else
  CLAUDE_CMD="claude --dangerously-skip-permissions --channels plugin:${CHANNEL_PLUGIN}"
fi
[[ -n "${CLAUDE_MODEL:-}" ]] && CLAUDE_CMD+=" --model ${CLAUDE_MODEL}"

tmux -L "$AGENT" new-session -d -s "$SESSION" \
  "${CHANNEL_ENV[@]}" \
  -e "CLAUDE_CHANNEL_PLUGIN=${CHANNEL_PLUGIN}" \
  -e "PATH=${PATH}" \
  "$CLAUDE_CMD"

# server: channels show an interactive "I am using this for local development"
# confirmation prompt on startup. Poll for the prompt and confirm when found,
# with a 30s timeout fallback in case the prompt text ever changes.
if [[ "$CHANNEL_PLUGIN" == server:* ]]; then
  (
    START=$(date +%s)
    while true; do
      sleep 1
      NOW=$(date +%s)
      pane=$(tmux -L "$AGENT" capture-pane -t "$SESSION" -p 2>/dev/null) || break
      if echo "$pane" | grep -q "I am using this for local development"; then
        tmux -L "$AGENT" send-keys -t "$SESSION" "" Enter
        break
      fi
      if (( NOW - START >= 30 )); then
        echo "$(date -Iseconds) [startup] confirm timeout for ${AGENT} — sending Enter anyway" >&2
        tmux -L "$AGENT" send-keys -t "$SESSION" "" Enter
        break
      fi
    done
  ) &
fi

# Agent-specific startup notification once Claude has had time to fully initialize (~20s).
# Uses CLAUDE_CHANNEL_PLUGIN to route to the right backend (Telegram or Matrix).
# Customize per-agent messages here, or leave the default:
case "$AGENT" in
  # my-agent)   _STARTUP_MSG="Coming online..." ;;
  *)          _STARTUP_MSG="Back online" ;;
esac
( sleep 20 && CLAUDE_CHANNEL_PLUGIN="${CHANNEL_PLUGIN}" "$(dirname "$0")/claude-notify" "$AGENT" "${_STARTUP_MSG}${CLAUDE_MODEL:+ (${CLAUDE_MODEL})}" 2>/dev/null || true ) &
unset _STARTUP_MSG

# Inject a greeting prompt into the Claude session at 25s so Claude actively greets
# the user through the channel — confirming the AI layer is responsive, not just the process.
# Skipped for Matrix agents: the MCP blocks sends to rooms with no prior inbound messages,
# so proactive greetings fail silently. Matrix agents greet naturally on first user message.
# (See beads ticket for plugin fix to pre-authorize rooms from access.json.)
if [[ "$CHANNEL_PLUGIN" != server:matrix ]]; then
  ( sleep 25 && tmux -L "$AGENT" send-keys -t "$SESSION" "You just came back online. Your active channel is Telegram. Send the user a brief greeting." Enter ) &
fi

# Stay alive while the session exists. When claude exits the tmux window closes,
# the session is destroyed, this loop exits, and systemd restarts the service.
#
# Health check: the channel bridge process can die while claude stays alive, leaving
# the bot silently unresponsive. Track which process to watch based on channel type:
#   telegram@*    → bun (official Claude Code Telegram plugin)
#   server:matrix → cc_matrix_channel (Rust binary, managed by Claude as MCP child)
#
# For server: channels, Claude manages the subprocess lifecycle, so we only watch
# for prolonged absence without active tool work (same logic, different process name).
HEALTH_GRACE=45  # seconds to wait after launch before checking for the bridge
LAUNCH_TIME=$(date +%s)
BUN_MISSING_SINCE=""

# Determine which process name to health-check.
if [[ "$CHANNEL_PLUGIN" == server:matrix ]]; then
  BRIDGE_PROC="cc_matrix_ch"  # truncated to 15 chars (Linux comm limit)
else
  BRIDGE_PROC="bun"
fi

# Recursively collect all descendant PIDs of $1 (one PID per line).
descendants() {
  local parent=$1
  local kids
  kids=$(pgrep -P "$parent" 2>/dev/null) || return 0
  for kid in $kids; do
    echo "$kid"
    descendants "$kid"
  done
}

while tmux -L "$AGENT" has-session -t "$SESSION" 2>/dev/null; do
  sleep 10

  # Skip health checks during startup grace period.
  NOW=$(date +%s)
  if (( NOW - LAUNCH_TIME < HEALTH_GRACE )); then
    continue
  fi

  # Walk the full process tree to detect bun and active tool processes.
  PANE_PID=$(tmux -L "$AGENT" list-panes -t "$SESSION" -F '#{pane_pid}' 2>/dev/null) || continue

  HAS_BUN=false
  HAS_TOOL=false
  while read -r pid; do
    [[ -z "$pid" ]] && continue
    cmd=$(ps -p "$pid" -o comm= 2>/dev/null) || continue
    case "$cmd" in
      ${BRIDGE_PROC}*) HAS_BUN=true ;;
      claude*)         ;;  # the agent itself — not a tool
      *)               HAS_TOOL=true ;;
    esac
  done < <(descendants "$PANE_PID")

  if $HAS_BUN; then
    BUN_MISSING_SINCE=""
    continue
  fi

  if $HAS_TOOL; then
    # Claude is actively running tools — don't penalise for bun absence.
    [[ -n "$BUN_MISSING_SINCE" ]] && \
      echo "$(date -Iseconds) [health] active tool work detected, resetting bridge timer for ${AGENT}" >&2
    BUN_MISSING_SINCE=""
    continue
  fi

  # No bun, no active tools — start (or continue) the missing timer.
  if [[ -z "$BUN_MISSING_SINCE" ]]; then
    BUN_MISSING_SINCE=$NOW
    echo "$(date -Iseconds) [health] bridge process (${BRIDGE_PROC}) not found for ${AGENT}, watching..." >&2
    continue
  fi

  # If bun has been missing for over 5 minutes, kill the session to trigger restart.
  if (( NOW - BUN_MISSING_SINCE > 300 )); then
    echo "$(date -Iseconds) [health] bridge missing for 5m — killing session ${SESSION} for restart" >&2
    tmux -L "$AGENT" kill-server 2>/dev/null || true
    break
  fi
done
