#!/usr/bin/env bash
# Usage: claude-notify <agent-name> <message>
# Delegates to matrix-notify or telegram-notify based on CLAUDE_CHANNEL_PLUGIN.
# Defaults to telegram if unset — existing agents keep working unchanged.
set -euo pipefail

AGENT="${1:?agent name required}"
MESSAGE="${2:?message required}"

DIR="$(dirname "$0")"
case "${CLAUDE_CHANNEL_PLUGIN:-telegram@claude-plugins-official}" in
  matrix@*|server:matrix)
    exec "$DIR/matrix-notify" "$AGENT" "$MESSAGE"
    ;;
  *)
    exec "$DIR/telegram-notify" "$AGENT" "$MESSAGE"
    ;;
esac
