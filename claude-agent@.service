[Unit]
Description=Claude agent - %i
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/agents/%i
Environment=PATH=%h/.bun/bin:%h/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Telegram (default — active for unmigrated agents)
Environment=TELEGRAM_STATE_DIR=%h/.claude/channels/telegram-%i
EnvironmentFile=-%h/.claude/channels/telegram-%i/.env

# Matrix (set CLAUDE_CHANNEL_PLUGIN=server:matrix in agent .env; config via .claude.json mcpServers)
EnvironmentFile=-%h/.claude/channels/matrix-%i/.env

ExecStart=%h/.local/bin/claude-tmux-launch %i
ExecStop=-/usr/bin/tmux -L %i kill-server
ExecStopPost=%h/.local/bin/claude-notify %i "Went offline — restarting in 10s."
TimeoutStopSec=15
KillMode=control-group
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Memory cap — restart cleanly before system-wide OOM is triggered
# MemoryHigh: soft limit — kernel applies GC pressure to V8 (1.5G→2G window)
# MemoryMax: hard kill — clean restart before system-wide OOM
MemoryHigh=1500M
MemoryMax=2G
MemorySwapMax=0

[Install]
WantedBy=default.target
