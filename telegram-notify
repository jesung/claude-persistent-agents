#!/usr/bin/env bash
# Usage: telegram-notify <agent-name> <message>
# Sends a Telegram message to the agent's configured allowFrom[0] chat ID.
# Expects TELEGRAM_BOT_TOKEN and TELEGRAM_STATE_DIR in the environment
# (both are set by the claude-agent@.service unit).
set -euo pipefail

AGENT="${1:?agent name required}"
MESSAGE="${2:?message required}"

TOKEN="${TELEGRAM_BOT_TOKEN:?TELEGRAM_BOT_TOKEN not set}"
STATE_DIR="${TELEGRAM_STATE_DIR:?TELEGRAM_STATE_DIR not set}"

CHAT_ID=$(python3 -c "
import json, sys
try:
    data = json.load(open('${STATE_DIR}/access.json'))
    print(data['allowFrom'][0])
except Exception as e:
    sys.exit(1)
") || { echo "telegram-notify: could not read chat ID from ${STATE_DIR}/access.json" >&2; exit 1; }

curl -s -X POST "https://api.telegram.org/bot${TOKEN}/sendMessage" \
    -H "Content-Type: application/json" \
    -d "{\"chat_id\": \"${CHAT_ID}\", \"text\": \"[${AGENT}] ${MESSAGE}\"}" \
    > /dev/null
