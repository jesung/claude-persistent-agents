#!/usr/bin/env bash
# check-cc-matrix-updates — check for new releases of cc_matrix_channel,
# run a Claude security review on the diff, build from source, install, and restart the agent.
# Designed to be run by a systemd timer.
#
# Required environment variables (set in the .service file):
#   NOTIFY_AGENT            — agent name to route notifications through
#   CLAUDE_CHANNEL_PLUGIN   — channel backend (e.g. server:matrix, telegram@...)
#   MATRIX_STATE_DIR        — state dir for matrix-notify (Matrix agents only)
#   MATRIX_ACCESS_TOKEN     — access token (Matrix agents only)
#
# Optional:
#   AGENT_SERVICE           — systemd service instance to restart (default: claude-agent@$NOTIFY_AGENT)

set -euo pipefail

REPO="IA-PieroCV/cc_matrix_channel"
CACHE="${XDG_STATE_HOME:-$HOME/.local/state}/cc-matrix-last-seen-tag"
SRC_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/src/cc_matrix_channel"
BIN_DIR="${HOME}/.local/bin"
SECURITY_REPORTS_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/cc-matrix-security"
AGENT="${NOTIFY_AGENT:?NOTIFY_AGENT must be set}"
AGENT_SERVICE="${AGENT_SERVICE:-claude-agent@${AGENT}}"

notify() {
    "$(dirname "$0")/claude-notify" "$AGENT" "$1" 2>/dev/null || true
}

# Get latest release tag
LATEST=$(gh release view --repo "$REPO" --json tagName -q '.tagName' 2>/dev/null || true)

# Fall back to git ls-remote if gh fails
if [[ -z "$LATEST" ]]; then
    LATEST=$(git ls-remote --tags "https://github.com/$REPO" 2>/dev/null \
        | awk '{print $2}' | grep -v '\^{}' | sed 's|refs/tags/||' | sort -V | tail -1)
fi

[[ -z "$LATEST" ]] && { echo "Could not determine latest release" >&2; exit 1; }

mkdir -p "$(dirname "$CACHE")"
LAST=$(cat "$CACHE" 2>/dev/null || echo "")
echo "Latest: $LATEST  Last seen: ${LAST:-<none>}"

if [[ "$LATEST" == "$LAST" ]]; then
    echo "No update."
    exit 0
fi

echo "New version detected: $LATEST"

# Clone if first time, otherwise fetch and checkout the new tag
if [[ ! -d "$SRC_DIR/.git" ]]; then
    git clone "https://github.com/$REPO" "$SRC_DIR"
fi

cd "$SRC_DIR"
git fetch --tags --force
git checkout "$LATEST"

# --- Security review ---
# Diff the new release against the previous one and ask Claude to review it.
# Skipped on first run (no previous version to diff from).
if [[ -n "$LAST" ]]; then
    echo "Running security review ($LAST → $LATEST)..."

    DIFF=$(git diff "$LAST" "$LATEST" 2>/dev/null || git diff HEAD~1 HEAD)
    echo "Diff size: $(echo "$DIFF" | wc -l) lines"

    PROMPT="You are performing an automated security review of a third-party Rust binary (cc_matrix_channel by IA-PieroCV) that will run as an MCP server inside a Claude Code agent.

Review the git diff below (${LAST} → ${LATEST}) for security issues using the following methodology:

**STRIDE threat model:** Spoofing, Tampering, Repudiation, Information Disclosure, Denial of Service, Elevation of Privilege.

**OWASP Top 10:** Broken Access Control, Cryptographic Failures, Injection, Insecure Design, Security Misconfiguration, Vulnerable Components, Auth Failures, Software Integrity Failures, Logging Failures, SSRF.

**LLM/MCP-specific:** Prompt injection via inbound Matrix messages, tool misuse through crafted input, secrets exfiltration (the binary receives MATRIX_ACCESS_TOKEN and MATRIX_PASSWORD), context manipulation.

Only flag findings at 8/10+ confidence. For each finding include: Severity, Category, Description, Exploit scenario, Recommendation.

Context:
- Binary runs as a child process of Claude Code, exposing MCP tools
- Handles Matrix auth tokens, E2EE crypto (Olm/Megolm), inbound messages, outbound replies
- Has network access to the Matrix homeserver

--- DIFF (${LAST} → ${LATEST}) ---
${DIFF}
--- END DIFF ---

End your review with EXACTLY one of these verdict lines (nothing after it):
SECURITY_APPROVED
SECURITY_BLOCKED"

    REPORT_FILE=$(mktemp /tmp/cc-matrix-security-XXXXXX.md)

    claude --dangerously-skip-permissions --bare -p "$PROMPT" > "$REPORT_FILE" 2>&1 || true

    # Save report regardless of verdict
    mkdir -p "$SECURITY_REPORTS_DIR"
    REPORT_PATH="$SECURITY_REPORTS_DIR/$(date +%Y-%m-%d)-${LATEST}.md"
    cp "$REPORT_FILE" "$REPORT_PATH"
    rm "$REPORT_FILE"
    echo "Security report saved: $REPORT_PATH"

    if grep -q "^SECURITY_APPROVED$" "$REPORT_PATH"; then
        echo "Security review: APPROVED — proceeding to build."
    elif grep -q "^SECURITY_BLOCKED$" "$REPORT_PATH"; then
        echo "Security review: BLOCKED — aborting build."
        notify "cc_matrix_channel $LATEST BLOCKED by security review. Report: $REPORT_PATH"
        exit 1
    else
        echo "Security review: INCONCLUSIVE (no verdict found) — aborting build."
        notify "cc_matrix_channel $LATEST security review inconclusive — build aborted. Report: $REPORT_PATH"
        exit 1
    fi
fi

# --- Build ---
echo "Building $LATEST from source..."
if ! cargo build --release 2>&1; then
    notify "cc_matrix_channel $LATEST build FAILED — still on ${LAST:-unknown}. Check: journalctl --user -u check-cc-matrix-updates"
    exit 1
fi

# Install — copy to .new then mv to atomically replace without "text file busy"
cp "target/release/cc_matrix_channel" "$BIN_DIR/cc_matrix_channel.new"
mv "$BIN_DIR/cc_matrix_channel.new" "$BIN_DIR/cc_matrix_channel"
echo "Installed $LATEST to $BIN_DIR/cc_matrix_channel"

# Update cache
echo "$LATEST" > "$CACHE"

# First run — just build and cache, no restart or notification needed
if [[ -z "$LAST" ]]; then
    echo "First run — built and installed $LATEST."
    exit 0
fi

# Notify before restarting so the message goes out while the agent is still up
notify "cc_matrix_channel updated $LAST → $LATEST — security approved, rebuilt from source, restarting..."

systemctl --user restart "$AGENT_SERVICE"
echo "Restarted $AGENT_SERVICE."
